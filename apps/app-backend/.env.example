# Grep codebase for OSAC_WORKAROUND_REMOVE(...) to find dev-only paths to delete when server auth/TLS are production-ready.

# BFF server port (default: 3001)
PORT=3001

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# API mode (matrix):
#   mock — FULFILLMENT_API_URL ignored; built-in mock handlers
#   dev  — requires FULFILLMENT_API_URL; proxies /api/fulfillment/v1/*, /api/events/v1/*, /api/osac/public/v1/*
OSAC_API_MODE=mock

# Required when OSAC_API_MODE=dev (non-empty http(s) base URL of the fulfillment gateway)
# FULFILLMENT_API_URL=https://fulfillment.example.com

# Optional: PEM file path for private PKI (Undici Agent; scoped to fulfillment upstream only).
# Prefer full chain (server + issuing CA). NODE_EXTRA_CA_CERTS alone is unreliable for Undici.
# FULFILLMENT_TLS_CA_FILE=/path/to/ca-bundle.pem

# TEMP — dev only: disable TLS verification for fulfillment upstream (never in production).
# TEMP_FULFILLMENT_TLS_INSECURE=1

# TEMP — when set, BFF adds Authorization: Bearer <value> upstream only if the client sent no real Bearer token.
# TEMP_FULFILLMENT_STATIC_BEARER=

# TEMP dev only — if 401 because the browser still has an expired JWT in sessionStorage, set to 1 so the
# static bearer replaces Authorization on proxied routes (never on GET /capabilities).
# TEMP_FULFILLMENT_STATIC_BEARER_FORCE=1
